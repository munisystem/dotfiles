#!/bin/bash
set -euo pipefail

install_pkg() {
  local pkg="$1"
  case "$pkg" in
    asdf:yysushi/asdf-tig*)
      # tig ships only C source (no prebuilt macOS binary); this plugin compiles
      # it from the official jonas/tig release against a bundled ncurses. Block
      # pkg-config from resolving macOS system ncurses, whose $NCURSES60-versioned
      # symbols conflict with the bundled ncurses at link time.
      PKG_CONFIG_LIBDIR=/nonexistent mise use -g "$pkg"
      ;;
    *)
      mise use -g "$pkg"
      ;;
  esac
}

{{ range .packages.mise -}}
install_pkg "{{ . }}"
{{ end -}}
mise reshim
